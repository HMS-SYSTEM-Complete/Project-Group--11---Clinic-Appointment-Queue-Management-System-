#include <iostream>
#include <vector>

using namespace std;

class Solution 
{
    public:
        void removeDuplicates(vector<int>& nums) 
        {
            int strt = 0;

            for(int i = 1; i < nums.size(); i++)
            {
                if(nums[i] != nums[strt])
                {
                    strt++;
                    nums[strt] = nums[i]; 
                }
            }
            nums.resize(strt + 1);
        }
};

int main() 
{
    class Solution s1;
    vector<int> arr = {3,3,1,5,1,5,2};

    s1.removeDuplicates(arr);

    for(int i = 0; i < arr.size();i++)
    {
        cout<<arr[i]<<" ";
    }
    return 0;
}
